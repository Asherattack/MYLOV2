// ─── Year in Review View ──────────────────────────────────────────────────────
function YearInReviewView({ c, journals }) {
  const [loading, setLoading] = useState(false);
  const [review, setReview]   = useState(null);
  const [year, setYear]       = useState(new Date().getFullYear());

  const yearJournals = useMemo(() =>
    journals.filter(j => !j.archived && j.content?.trim() && new Date(j.created).getFullYear() === year),
    [journals, year]
  );

  const totalWords = yearJournals.reduce((a, j) => a + wc(j.content), 0);
  const totalEntries = yearJournals.length;

  const moodCounts = useMemo(() => {
    const m = {};
    MOODS.forEach(mood => { m[mood.id] = 0; });
    return m;
  }, []);

  const availableYears = [...new Set(journals.map(j => new Date(j.created).getFullYear()))].sort((a,b) => b - a);

  const generate = async () => {
    if (!yearJournals.length) return;
    setLoading(true);
    try {
      const sample = yearJournals
        .sort((a, b) => new Date(a.created) - new Date(b.created))
        .slice(0, 20)
        .map(j => `[${new Date(j.created).toLocaleDateString("en-US",{month:"short",day:"numeric"})} · ${j.type}] ${j.title}: ${j.content?.slice(0, 200).trim()}`)
        .join("\n\n");

      const res = await fetch("https://api.anthropic.com/v1/messages", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          model: "claude-sonnet-4-20250514",
          max_tokens: 1200,
          messages: [{
            role: "user",
            content: `You are writing a warm, personal, literary Year in Review for someone's private journal app called MYLOV. Based on their ${year} journal entries below, write a beautiful 4-6 paragraph retrospective that:
- Opens with the emotional weather of their year
- Names 2-3 specific recurring themes you notice (use their actual words where fitting)
- Identifies one moment of growth or shift
- Ends with a forward-looking sentence into next year
Write in second person ("you"), warmly, like a perceptive friend summarising their year back to them. Be specific, not generic. Total length: ~350 words.

Their ${year} entries (${totalEntries} total, ${totalWords} words):
${sample}`
          }]
        })
      });
      const data = await res.json();
      setReview(data.content?.find(b => b.type === "text")?.text || "Unable to generate review.");
    } catch(e) {
      setReview("Something went wrong. Please try again.");
    } finally {
      setLoading(false);
    }
  };

  return (
    <div style={{ maxWidth: 680, margin: "36px auto", padding: "0 28px 80px", animation: "fadeUp .22s ease" }}>
      <div style={{ display: "flex", alignItems: "center", justifyContent: "space-between", marginBottom: 6 }}>
        <div className="ff-serif" style={{ fontSize: 36, fontWeight: 300, color: c.text }}>Year in Review</div>
        <select value={year} onChange={e => { setYear(Number(e.target.value)); setReview(null); }}
          style={{ background: c.inputBg, border: `1px solid ${c.border}`, borderRadius: 7, padding: "6px 10px", fontSize: 13, color: c.text, cursor: "pointer" }}>
          {availableYears.map(y => <option key={y} value={y}>{y}</option>)}
        </select>
      </div>
      <div style={{ fontSize: 12, color: c.muted, marginBottom: 28 }}>
        {totalEntries} entries · {totalWords.toLocaleString()} words written in {year}
      </div>

      {/* Stats grid */}
      <div style={{ display: "grid", gridTemplateColumns: "repeat(3,1fr)", gap: 10, marginBottom: 28 }}>
        {[
          { l: "Entries", v: totalEntries },
          { l: "Words Written", v: totalWords.toLocaleString() },
          { l: "Journal Types", v: [...new Set(yearJournals.map(j => j.type))].length },
        ].map(s => (
          <div key={s.l} style={{ background: c.card, border: `1px solid ${c.border}`, borderRadius: 10, padding: "14px 16px" }}>
            <div className="ff-serif" style={{ fontSize: 28, fontWeight: 300, color: c.accent, lineHeight: 1 }}>{s.v}</div>
            <div style={{ fontSize: 9, color: c.muted, marginTop: 4, letterSpacing: ".1em", textTransform: "uppercase" }}>{s.l}</div>
          </div>
        ))}
      </div>

      {!review && !loading && (
        <div style={{ textAlign: "center", padding: "40px 20px", background: c.card, border: `1px solid ${c.border}`, borderRadius: 12, marginBottom: 24 }}>
          <div className="ff-serif" style={{ fontSize: 22, color: c.accent, marginBottom: 8, opacity: .5 }}>✦</div>
          <div className="ff-lora" style={{ fontSize: 14, color: c.muted, fontStyle: "italic", lineHeight: 1.7, marginBottom: 20 }}>
            Let MYHELPER read your {year} and write you a personal retrospective — your year in your own words, seen from the outside.
          </div>
          <Btn v={totalEntries < 3 ? "mb-dis" : "mb-primary"} disabled={totalEntries < 3} onClick={generate} style={{ padding: "10px 28px", fontSize: 13 }}>
            Generate My {year} Review
          </Btn>
          {totalEntries < 3 && <div style={{ fontSize: 10.5, color: c.muted, marginTop: 10 }}>Write at least 3 entries in {year} to generate a review.</div>}
        </div>
      )}

      {loading && (
        <div style={{ textAlign: "center", padding: "60px 20px" }}>
          <div style={{ display: "flex", justifyContent: "center", gap: 6, marginBottom: 16 }}>
            {[0,1,2].map(i => <span key={i} style={{ width: 7, height: 7, borderRadius: "50%", background: c.accent, display: "inline-block", animation: `dotPulse 1.2s ease ${i*.2}s infinite` }}/>)}
          </div>
          <div className="ff-lora" style={{ fontSize: 13, color: c.muted, fontStyle: "italic" }}>Reading your year…</div>
        </div>
      )}

      {review && (
        <div style={{ animation: "fadeUp .3s ease" }}>
          <div style={{ background: c.card, border: `1px solid ${c.border}`, borderLeft: `3px solid ${c.accent}`, borderRadius: "0 12px 12px 0", padding: "28px 32px", marginBottom: 20 }}>
            <div className="ff-serif" style={{ fontSize: 11, color: c.accent, letterSpacing: ".16em", textTransform: "uppercase", marginBottom: 18 }}>Your {year}</div>
            {review.split("\n\n").map((para, i) => (
              <p key={i} className="ff-lora" style={{ fontSize: 15.5, lineHeight: 1.85, color: c.text, marginBottom: 16 }}>{para}</p>
            ))}
          </div>
          <div style={{ display: "flex", gap: 8 }}>
            <Btn v="mb-ghost" onClick={() => setReview(null)} style={{ fontSize: 11 }}>↺ Regenerate</Btn>
            <Btn v="mb-ghost" onClick={() => {
              const blob = new Blob([`MYLOV — Year in Review ${year}\n\n${review}`], { type: "text/plain" });
              const a = document.createElement("a"); a.href = URL.createObjectURL(blob); a.download = `mylov-${year}-review.txt`; a.click();
            }} style={{ fontSize: 11 }}>↓ Save as text</Btn>
          </div>
        </div>
      )}
    </div>
  );
}

