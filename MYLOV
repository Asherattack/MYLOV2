  );
}

// ─── Sentence Focus Editor ─────────────────────────────────────────────────────
function SentenceFocusEditor({ c, journal, onUpdate, typewriter, focusMode }) {
  const [activeSent, setActiveSent] = useState(0);
  const taRef = useRef(null);

  const sentences = useMemo(() => {
    const raw = journal.content || "";
    return raw.split(/(?<=[.!?])\s+/).filter(Boolean);
  }, [journal.content]);

  const handleChange = (e) => onUpdate(journal.id, { content: e.target.value });

  const handleClick = (e) => {
    const ta = taRef.current;
    if (!ta) return;
    const pos = ta.selectionStart;
    let idx = 0, cumLen = 0;
    for (let i = 0; i < sentences.length; i++) {
      cumLen += sentences[i].length + (i < sentences.length - 1 ? 1 : 0);
      if (pos <= cumLen) { idx = i; break; }
    }
    setActiveSent(idx);
  };

  const isSerifType = journal.type === "stream" || journal.type === "gratitude" || journal.type === "dream";

  if (!sentences.length) {
    return (
      <textarea ref={taRef} autoFocus placeholder={getPlaceholder(journal.type)}
        value={journal.content||""} onChange={handleChange}
        style={{width:"100%",minHeight:"calc(100vh - 280px)",background:"transparent",border:"none",resize:"none",fontSize:focusMode?20:17,lineHeight:1.95,color:c.text,fontFamily:isSerifType?"'Lora',serif":"'DM Sans',sans-serif",caretColor:c.accent,maxWidth:"65ch"}}/>
    );
  }

  return (
    <div style={{ maxWidth: "65ch", position: "relative" }}>
      <div style={{ marginBottom: 16, padding: "8px 12px", background: c.card, border: `1px solid ${c.border}`, borderRadius: 8, fontSize: 10.5, color: c.muted, letterSpacing: ".05em" }}>
        ◎ Sentence focus — click any sentence to highlight it. Edit in the field below.
      </div>
      <div style={{ lineHeight: 2, fontSize: isSerifType ? 17 : 15, fontFamily: isSerifType ? "'Lora',serif" : "'DM Sans',sans-serif", marginBottom: 24, maxWidth: "65ch" }}>
        {sentences.map((s, i) => (
          <span key={i} onClick={() => setActiveSent(i)}
            style={{ color: i === activeSent ? c.text : c.muted, opacity: i === activeSent ? 1 : 0.28, cursor: "pointer", transition: "all .25s", borderBottom: i === activeSent ? `1px solid ${c.accent}` : "1px solid transparent", paddingBottom: 1 }}>
            {s}{i < sentences.length - 1 ? " " : ""}
          </span>
        ))}
      </div>
      <textarea ref={taRef} autoFocus
        value={journal.content || ""} onChange={handleChange} onClick={handleClick}
        placeholder="Keep writing…"
        style={{ width: "100%", minHeight: 180, background: c.inputBg, border: `1px solid ${c.border}`, borderRadius: 9, resize: "none", fontSize: isSerifType ? 17 : 15, lineHeight: 1.95, color: c.text, fontFamily: isSerifType ? "'Lora',serif" : "'DM Sans',sans-serif", caretColor: c.accent, padding: "12px 14px" }}
        onFocus={e => e.target.style.borderColor = c.accent} onBlur={e => e.target.style.borderColor = c.border} />
    </div>
  );
}

// ─── Ambient Sound Player ─────────────────────────────────────────────────────
function AmbientPlayer({ soundId }) {
  const ctxRef  = useRef(null);
  const nodesRef = useRef([]);

  useEffect(() => {
    const AudioCtx = window.AudioContext || window.webkitAudioContext;
    if (!AudioCtx) return;
    const ctx = new AudioCtx();
    ctxRef.current = ctx;

    const nodes = [];
    const makeNoise = () => {
      const buf = ctx.createBuffer(1, ctx.sampleRate * 2, ctx.sampleRate);
      const data = buf.getChannelData(0);
      for (let i = 0; i < data.length; i++) data[i] = Math.random() * 2 - 1;
      return buf;
    };

    if (soundId === "rain") {
      const src = ctx.createBufferSource(); src.buffer = makeNoise(); src.loop = true;
      const filter = ctx.createBiquadFilter(); filter.type = "bandpass"; filter.frequency.value = 1200; filter.Q.value = 0.3;
      const gain = ctx.createGain(); gain.gain.value = 0.08;
      src.connect(filter); filter.connect(gain); gain.connect(ctx.destination);
      src.start(); nodes.push(src);
    } else if (soundId === "fire") {
      const src = ctx.createBufferSource(); src.buffer = makeNoise(); src.loop = true;
      const filter = ctx.createBiquadFilter(); filter.type = "lowpass"; filter.frequency.value = 300;
      const gain = ctx.createGain(); gain.gain.value = 0.12;
      src.connect(filter); filter.connect(gain); gain.connect(ctx.destination);
      const crackleOsc = ctx.createOscillator(); crackleOsc.frequency.value = 60;
      const crackleGain = ctx.createGain(); crackleGain.gain.value = 0.04;
      crackleOsc.connect(crackleGain); crackleGain.connect(ctx.destination);
      src.start(); crackleOsc.start(); nodes.push(src, crackleOsc);
    } else if (soundId === "cafe") {
      [400, 600, 800, 1200].forEach(f => {
        const src = ctx.createBufferSource(); src.buffer = makeNoise(); src.loop = true;
        const filter = ctx.createBiquadFilter(); filter.type = "bandpass"; filter.frequency.value = f; filter.Q.value = 4;
        const gain = ctx.createGain(); gain.gain.value = 0.018;
        src.connect(filter); filter.connect(gain); gain.connect(ctx.destination);
        src.start(); nodes.push(src);
      });
    } else if (soundId === "forest") {
      [800, 1600, 3200].forEach(f => {
        const src = ctx.createBufferSource(); src.buffer = makeNoise(); src.loop = true;
        const filter = ctx.createBiquadFilter(); filter.type = "bandpass"; filter.frequency.value = f; filter.Q.value = 0.5;
        const gain = ctx.createGain(); gain.gain.value = 0.025;
        src.connect(filter); filter.connect(gain); gain.connect(ctx.destination);
        src.start(); nodes.push(src);
      });
    } else if (soundId === "waves") {
      const src = ctx.createBufferSource(); src.buffer = makeNoise(); src.loop = true;
      const filter = ctx.createBiquadFilter(); filter.type = "lowpass"; filter.frequency.value = 600;
      const lfo = ctx.createOscillator(); lfo.frequency.value = 0.2;
      const lfoGain = ctx.createGain(); lfoGain.gain.value = 0.04;
      const masterGain = ctx.createGain(); masterGain.gain.value = 0.1;
      lfo.connect(lfoGain); lfoGain.connect(masterGain.gain);
      src.connect(filter); filter.connect(masterGain); masterGain.connect(ctx.destination);
      src.start(); lfo.start(); nodes.push(src, lfo);
    }

    nodesRef.current = nodes;
    return () => { nodes.forEach(n => { try { n.stop(); } catch(e){} }); ctx.close(); };
  }, [soundId]);

  return null;
}

